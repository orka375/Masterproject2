<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4026.18">
  <POU Name="FB_ROB" Id="{7ce28b50-28f8-4d4c-bb25-1006bf064637}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_ROB IMPLEMENTS ITF_6AxisRobot

VAR_OUTPUT
	_inCollision: BOOL;
	_inHomePosition: BOOL;
END_VAR
VAR
	_id: UINT;
	{attribute 'instance-path'}
	_spath: STRING;
	{attribute 'instance-name'}
	_sname: STRING;
	
	_state: eState := eState.Unconfigured;
	_enabled: BOOL;
	_mode: eMode;
	_locked: BOOL;
	
	tcppos, tcpvel : stPose3D;
	jointpos, jointvel: stJointPosition6;
	currFrame: stFrame;
	currTool: FB_Tool;
	velovr: BOOL;
	velfact: REAL;
	
	
	dummy: INT;
END_VAR

VAR
	transitionresult: ERESULT;
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[//State Machine

CASE _state OF
	eState.Unconfigured:
		dummy:=1;
	eState.Inactive:
		dummy:=1;
	eState.Active:
		dummy:=1;
	eState.Finalized:
		destroy();
		
END_CASE]]></ST>
    </Implementation>
    <Folder Name="Done" Id="{d14dad14-4780-4b1d-94ed-a217c650169e}" />
